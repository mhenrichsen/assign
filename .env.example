# Path to the SQLite file backing short URLs.
# In production (Coolify), point this at a mounted volume directory, e.g. /app/data/links.db.
LINKS_DB_PATH=./data/links.db

# Public-facing origin for absolute URLs in OG metadata (Discord requires absolute image URLs).
# In production set this to your real domain, e.g. https://assign.example.com.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
